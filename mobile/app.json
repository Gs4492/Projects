{
  "expo": {
    "name": "PulseAI",
    "slug": "pulseai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["android"],
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow PulseAI to use the microphone.",
          "speechRecognitionPermission": "Allow PulseAI to recognize speech.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ],
    "android": {
      "package": "com.pulseai.mobile"
    }
  }
}